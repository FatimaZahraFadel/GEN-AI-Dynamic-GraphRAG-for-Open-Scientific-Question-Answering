# Required
GROQ_API_KEY=

# Optional but recommended
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=

# Optional: local Ollama fallback for extraction
USE_OLLAMA_EXTRACTION_FALLBACK=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EXTRACTION_MODEL=llama3.1:8b

# Optional: Ollama-primary mode for planner/retriever/answer/evaluator
USE_OLLAMA_PRIMARY=0
OLLAMA_GENERAL_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=60
